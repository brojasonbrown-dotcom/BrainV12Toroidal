# RHUFT v13 — API Keys & Tool Configuration
# Copy this file to `.env` and fill in your actual keys.
# NEVER commit `.env` to git.

# ═══════════════════════════════════════════════════════════════════════════════
# Wolfram / Mathematica API
# ═══════════════════════════════════════════════════════════════════════════════
# WolframAlpha API: https://products.wolframalpha.com/api/
WOLFRAM_ALPHA_APP_ID=your_wolfram_alpha_app_id_here

# Wolfram Cloud API (for Wolfram Language calls)
WOLFRAM_CLOUD_API_KEY=your_wolfram_cloud_api_key_here
WOLFRAM_CLOUD_BASE_URL=https://www.wolframcloud.com

# ═══════════════════════════════════════════════════════════════════════════════
# GitHub CLI / GitHub API
# ═══════════════════════════════════════════════════════════════════════════════
# Only needed if using GitHub Actions or API directly.
# For normal git push, use HTTPS with a personal access token or SSH key.
GITHUB_TOKEN=your_github_personal_access_token_here

# ═══════════════════════════════════════════════════════════════════════════════
# Azure / OpenAI / Foundry (if used)
# ═══════════════════════════════════════════════════════════════════════════════
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your_azure_openai_key_here
AZURE_OPENAI_DEPLOYMENT=your-deployment-name

OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ═══════════════════════════════════════════════════════════════════════════════
# Lovable (if used for UI generation)
# ═══════════════════════════════════════════════════════════════════════════════
LOVABLE_API_KEY=your_lovable_api_key_here

# ═══════════════════════════════════════════════════════════════════════════════
# Other computational tools
# ═══════════════════════════════════════════════════════════════════════════════
# Add any other API keys below as needed.
